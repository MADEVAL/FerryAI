# Export-ignore: excluded from release archive downloads
/.github            export-ignore
/tests              export-ignore
/benchmarks         export-ignore
/docs               export-ignore
/native-binaries    export-ignore
/tmp                export-ignore

# Normalize line endings
*                   text=auto

# Specific files
*.php               text eol=lf diff=php
*.md                text eol=lf
*.json              text eol=lf
*.xml               text eol=lf
*.neon              text eol=lf
*.yml               text eol=lf
*.yaml              text eol=lf
*.dist              text eol=lf
*.sh                text eol=lf
*.bat               text eol=crlf
