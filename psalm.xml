<?xml version="1.0"?>
<psalm
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    errorLevel="3"
    findUnusedCode="false"
    cacheDirectory="build/psalm"
>
    <projectFiles>
        <directory name="packages/core/src"/>
        <directory name="packages/tensor/src"/>
        <directory name="packages/onnx-backend/src"/>
        <directory name="packages/llama-backend/src"/>
        <directory name="packages/tokenizer/src"/>
        <directory name="packages/embedding/src"/>
        <directory name="packages/vector/src"/>
        <directory name="packages/model-hub/src"/>
        <directory name="packages/pipeline/src"/>
        <directory name="packages/cpu-backend/src"/>
        <directory name="packages/laravel/src"/>
        <directory name="packages/symfony/src"/>
        <directory name="packages/ai/src"/>
        <ignoreFiles>
            <directory name="packages/*/tests"/>
            <directory name="vendor"/>
            <!-- Native ONNX Runtime FFI boundary (untyped third-party FFI); covered by integration tests. -->
            <file name="packages/onnx-backend/src/OnnxRuntimeFactory.php"/>
            <file name="packages/onnx-backend/src/Runtime/NativeOnnxRuntime.php"/>
            <file name="packages/onnx-backend/src/Runtime/NativeOnnxSession.php"/>
            <file name="packages/tokenizer/src/HuggingFaceTokenizer.php"/>
            <file name="packages/llama-backend/src/FFI/LlamaCpp.php"/>
            <file name="packages/llama-backend/src/FFI/LlamaContext.php"/>
            <file name="packages/llama-backend/src/FFI/LlamaBatch.php"/>
            <file name="packages/llama-backend/src/Runtime/NativeLlamaRuntime.php"/>
            <file name="packages/llama-backend/src/Runtime/NativeLlamaSession.php"/>
        </ignoreFiles>
    </projectFiles>

    <issueHandlers>
        <!-- FFI: unavoidable type mismatches -->
        <MixedPropertyFetch errorLevel="suppress"/>
        <MixedMethodCall errorLevel="suppress"/>
        <MixedArgument errorLevel="suppress"/>
        <MixedAssignment errorLevel="suppress"/>
        <MixedReturnStatement errorLevel="suppress"/>
        <MixedReturnTypeCoercion errorLevel="suppress"/>
    </issueHandlers>
</psalm>
