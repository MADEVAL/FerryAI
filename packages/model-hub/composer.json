{
    "name": "ferry-ai/inference-model-hub",
    "description": "FerryAI model hub: download, cache, verify and inspect AI models",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/MADEVAL/FerryAI",
    "authors": [
        {
            "name": "Yevhen Leonidov",
            "homepage": "https://github.com/MADEVAL"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ferry-ai/inference-core": "^0.1.0",
        "ext-hash": "*",
        "ext-zip": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0 || ^13.0",
        "phpstan/phpstan": "^2.0",
        "vimeo/psalm": "^6.0"
    },
    "suggest": {
        "ext-sodium": "For Ed25519 signature verification",
        "ext-curl": "For HTTP downloads from HuggingFace Hub"
    },
    "autoload": {
        "psr-4": {
            "FerryAI\\ModelHub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FerryAI\\ModelHub\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
