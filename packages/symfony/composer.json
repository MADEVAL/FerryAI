{
    "name": "ferry-ai/inference-symfony",
    "description": "FerryAI Symfony integration: bundle and DI extension",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/MADEVAL/FerryAI",
    "authors": [
        {
            "name": "Yevhen Leonidov",
            "homepage": "https://github.com/MADEVAL"
        }
    ],
    "require": {
        "php": ">=8.5",
        "ferry-ai/inference-ai": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0 || ^13.0"
    },
    "suggest": {
        "symfony/http-kernel": "For Symfony bundle integration"
    },
    "autoload": {
        "psr-4": {
            "FerryAI\\Symfony\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
