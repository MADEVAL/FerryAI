{
    "name": "ferry-ai/inference-laravel",
    "description": "FerryAI Laravel integration: service provider and facade",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/MADEVAL/FerryAI",
    "authors": [
        {
            "name": "Yevhen Leonidov",
            "homepage": "https://github.com/MADEVAL"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ferry-ai/inference-ai": "^0.1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0 || ^13.0",
        "phpstan/phpstan": "^2.0",
        "vimeo/psalm": "^6.0"
    },
    "suggest": {
        "laravel/framework": "For Laravel service provider and facade integration",
        "illuminate/support": "Required for Laravel ServiceProvider base class"
    },
    "autoload": {
        "psr-4": {
            "FerryAI\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FerryAI\\Laravel\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
