{
    "name": "ferry-ai/inference-pipeline",
    "description": "FerryAI pipeline: composable processing stages with generator-based execution",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/MADEVAL/FerryAI",
    "authors": [
        {
            "name": "Yevhen Leonidov",
            "homepage": "https://github.com/MADEVAL"
        }
    ],
    "require": {
        "php": ">=8.5",
        "ferry-ai/inference-core": "^0.1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0 || ^13.0",
        "phpstan/phpstan": "^2.0",
        "vimeo/psalm": "^6.0"
    },
    "suggest": {
        "ferry-ai/inference-embedding": "For EmbedStage",
        "ferry-ai/inference-tokenizer": "For TokenizeStage and ChunkStage",
        "ferry-ai/inference-vector": "For StoreStage"
    },
    "autoload": {
        "psr-4": {
            "FerryAI\\Pipeline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FerryAI\\Pipeline\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
