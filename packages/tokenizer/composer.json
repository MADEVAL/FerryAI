{
    "name": "ferry-ai/inference-tokenizer",
    "description": "FerryAI tokenizers: pure-PHP BPE/WordPiece and native HuggingFace tokenizers via FFI",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/MADEVAL/FerryAI",
    "authors": [
        {
            "name": "Yevhen Leonidov",
            "homepage": "https://github.com/MADEVAL"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ferry-ai/inference-core": "^0.1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0 || ^13.0",
        "phpstan/phpstan": "^2.0",
        "vimeo/psalm": "^6.0"
    },
    "suggest": {
        "ext-ffi": "Required at runtime by the native HuggingFace tokenizer binding"
    },
    "autoload": {
        "psr-4": {
            "FerryAI\\Tokenizer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FerryAI\\Tokenizer\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
