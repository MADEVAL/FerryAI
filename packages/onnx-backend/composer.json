{
    "name": "ferry-ai/inference-onnx-backend",
    "description": "FerryAI ONNX Runtime backend (execution providers; FFI runtime added in the FFI layer)",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/MADEVAL/FerryAI",
    "authors": [
        {
            "name": "Yevhen Leonidov",
            "homepage": "https://github.com/MADEVAL"
        }
    ],
    "require": {
        "php": ">=8.5",
        "ferry-ai/inference-core": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0 || ^13.0",
        "phpstan/phpstan": "^2.0",
        "vimeo/psalm": "^6.0"
    },
    "suggest": {
        "phpmlkit/onnxruntime": "Native ONNX Runtime FFI bindings (required for real inference)"
    },
    "autoload": {
        "psr-4": {
            "FerryAI\\OnnxBackend\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FerryAI\\OnnxBackend\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
